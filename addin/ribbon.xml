<?xml version="1.0" encoding="UTF-8"?>
<!--
  WPS 功能区定义。格式遵循 wpsjs 约定（customUI / ribbon）。
  注意：此 XML 的精确命名空间与标签集随 wpsjs 版本而异，
  [人工] 需用本机已装 wpsjs 版本生成的样板核对，不要假设本文件直接可用。

  onLoad   -> ribbon.OnAddinLoad（缓存 ribbonUI，宿主回调）
  onAction -> ribbon.OnAction（按钮点击，显示任务窗格）
  getImage -> ribbon.GetImage（按钮图标，Phase 0 可返回空/占位）
-->
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="ribbon.OnAddinLoad">
  <ribbon>
    <tabs>
      <tab id="maxieTab" label="Maxie">
        <group id="maxieGroup" label="Maxie">
          <button id="maxieOpenPane"
                  label="打开 Maxie"
                  onAction="ribbon.OnAction"
                  getImage="ribbon.GetImage"
                  size="large" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
